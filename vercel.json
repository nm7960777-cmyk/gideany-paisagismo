{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "redirects": [
    {
      "source": "/paisagismo-sao-roque",
      "destination": "/servicos/paisagismo",
      "permanent": true
    },
    {
      "source": "/paisagismo-cotia",
      "destination": "/servicos/paisagismo",
      "permanent": true
    },
    {
      "source": "/paisagismo-sorocaba",
      "destination": "/servicos/paisagismo",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
